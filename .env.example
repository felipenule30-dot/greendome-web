# Django core
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Internationalization
LANGUAGE_CODE=es-es
TIME_ZONE=America/Bogota

# Database (SQLite por defecto; cambiar para PostgreSQL/MySQL en producción)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# django-meta
META_SITE_PROTOCOL=https
META_SITE_DOMAIN=yourdomain.com
META_SITE_NAME=GreenDome
META_INCLUDE_KEYWORDS=greendome,sostenibilidad,medioambiente
META_DEFAULT_KEYWORDS=greendome,sostenibilidad

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.yourdomain.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@yourdomain.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
